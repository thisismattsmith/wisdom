---
interface Card {
  step: string;
  ask: string;
}
interface Result {
  rtag: string;
  title: string;
  tone: 'go' | 'stay';
}
interface Props {
  heading?: string;
  lead?: string;
  start: string;
  leftHead: string;
  leftCards: Card[];
  leftFoot?: string;
  rightHead: string;
  rightCards: Card[];
  rightFoot?: string;
  weighLabel?: string;
  results: [Result, Result];
}
const {
  heading,
  lead,
  start,
  leftHead,
  leftCards,
  leftFoot = 'All → Yes',
  rightHead,
  rightCards,
  rightFoot = 'All → Yes',
  weighLabel = 'Weigh the two sides against each other',
  results,
} = Astro.props;
---
<section class="flow">
  <div class="wrap">
    {heading && <h2>{heading}</h2>}
    {lead && <p class="lead">{lead}</p>}

    <div class="chart">
      <div class="fc-start">{start}</div>
      <div class="fc-arrow"></div>

      <div class="fc-columns">
        <div class="fc-col correct">
          <div class="fc-col-head">{leftHead}</div>
          {leftCards.map((c) => (
            <div class="fc-card">
              <div class="step">{c.step}</div>
              <div class="ask">{c.ask}</div>
            </div>
          ))}
          <div class="fc-col-foot">{leftFoot}</div>
        </div>

        <div class="fc-col silent">
          <div class="fc-col-head">{rightHead}</div>
          {rightCards.map((c) => (
            <div class="fc-card">
              <div class="step">{c.step}</div>
              <div class="ask">{c.ask}</div>
            </div>
          ))}
          <div class="fc-col-foot">{rightFoot}</div>
        </div>
      </div>

      <div class="fc-arrow short"></div>
      <div class="fc-weigh">{weighLabel}</div>
      <div class="fc-arrow"></div>

      <div class="fc-end">
        {results.map((r) => (
          <div class={`fc-result ${r.tone}`}>
            <div class="rtag">{r.rtag}</div>
            <h4>{r.title}</h4>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .flow {
    padding: 48px 0;
    border-top: 1px solid var(--hairline);
  }
  h2 {
    font-size: 32px;
    line-height: 1.2;
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .lead {
    font-size: 16px;
    line-height: 1.5;
    color: var(--mute);
    max-width: 90ch;
    margin-bottom: 48px;
  }
  .chart {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .fc-start {
    background: var(--ink);
    color: #fff;
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 14px 32px;
    border-radius: 30px;
    text-align: center;
    max-width: 520px;
  }
  .fc-arrow {
    width: 1px;
    height: 28px;
    background: var(--ink);
    position: relative;
    flex: 0 0 auto;
  }
  .fc-arrow::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 7px solid var(--ink);
  }
  .fc-arrow.short { height: 18px; }

  .fc-columns {
    display: flex;
    gap: 8px;
    width: 100%;
    max-width: 840px;
  }
  .fc-col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .fc-col-head {
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 14px 18px;
  }
  .fc-col.correct .fc-col-head {
    background: var(--ink);
    color: #fff;
  }
  .fc-col.silent .fc-col-head {
    background: var(--soft-cloud);
    color: var(--ink);
    border: 1px solid var(--hairline);
  }
  .fc-card {
    border: 1px solid var(--hairline);
    border-top: none;
    padding: 18px;
    background: var(--canvas);
  }
  .fc-card .step {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mute);
    margin-bottom: 6px;
  }
  .fc-card .ask {
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
  }
  .fc-col-foot {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mute);
    text-align: center;
    padding: 12px;
    border: 1px solid var(--hairline);
    border-top: none;
  }
  .fc-weigh {
    background: var(--soft-cloud);
    border: 1px solid var(--hairline);
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 14px 32px;
    text-align: center;
    max-width: 560px;
  }
  .fc-end {
    display: flex;
    gap: 8px;
    width: 100%;
    max-width: 560px;
  }
  .fc-result {
    flex: 1;
    padding: 24px;
    text-align: center;
  }
  .fc-result.go {
    background: var(--ink);
    color: #fff;
  }
  .fc-result.stay {
    background: var(--soft-cloud);
    color: var(--ink);
    border: 1px solid var(--hairline);
  }
  .rtag {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .fc-result.go .rtag { color: #9e9ea0; }
  .fc-result.stay .rtag { color: var(--mute); }
  h4 {
    font-size: 20px;
    font-weight: 500;
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    h2 { font-size: 24px; }
    .fc-columns { flex-direction: column; }
    .fc-end { flex-direction: column; }
  }
</style>
