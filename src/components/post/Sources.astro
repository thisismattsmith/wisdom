---
interface Source {
  label: string;
  url: string;
  note?: string;
}
interface Props {
  heading?: string;
  sources: Source[];
}
const { heading = 'Sources', sources } = Astro.props;
---
<section class="sources">
  <div class="wrap">
    <div class="label">{heading}</div>
    <ul>
      {sources.map((s) => (
        <li>
          <a href={s.url} rel="noopener" target="_blank">{s.label}</a>
          {s.note && <span class="note"> — {s.note}</span>}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .sources {
    padding: 48px 0;
    border-top: 1px solid var(--hairline);
  }
  .label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mute);
    margin-bottom: 18px;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    padding: 12px 0;
    border-bottom: 1px solid var(--hairline-soft);
    font-size: 14px;
    line-height: 1.5;
  }
  li:last-child {
    border-bottom: none;
  }
  a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }
  .note {
    color: var(--mute);
  }
</style>
