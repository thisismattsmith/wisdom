---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/post/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts
  .map((p) => ({ slug: p.slug, data: p.data }))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---
<BaseLayout title="Plain Sense — Old Ideas, Made Useful">
  <Hero eyebrow="Plain Sense" title={"Old Ideas,\nMade Useful."}>
    A small library of classical and historical writing, translated into plain language and simple decision frameworks for the way we argue now. One old idea at a time.
  </Hero>

  <section class="library" data-pagefind-ignore>
    <div class="wrap">
      <div class="filters">
        <label class="search-label" for="search">Search</label>
        <input
          type="search"
          id="search"
          placeholder="Search the full text of every post…"
          aria-label="Search posts"
        />
        <div class="tags" id="tags" role="group" aria-label="Filter by tag">
          <button class="tag-chip active" data-tag="" type="button">All</button>
          {allTags.map((tag) => (
            <button class="tag-chip" data-tag={tag} type="button">
              {tag.replace(/-/g, ' ')}
            </button>
          ))}
        </div>
      </div>

      <div class="results-line">
        <span id="results-count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
        <span id="results-status" class="status" hidden></span>
      </div>

      <div class="posts-grid" id="posts-grid">
        {posts.map(({ slug, data }) => (
          <PostCard
            slug={slug}
            title={data.title}
            excerpt={data.excerpt}
            tags={data.tags}
            sourceAuthor={data.sourceAuthor}
            sourceYear={data.sourceYear}
          />
        ))}
      </div>
      <p class="empty" id="empty" hidden>No posts match your search.</p>
    </div>
  </section>

  <script>
    type PagefindModule = {
      init: () => Promise<void>;
      search: (query: string | null, opts?: { filters?: Record<string, string> }) => Promise<{
        results: Array<{ data: () => Promise<{ url: string; meta: Record<string, string> }> }>;
      }>;
    };

    const searchEl = document.getElementById('search') as HTMLInputElement | null;
    const grid = document.getElementById('posts-grid');
    const empty = document.getElementById('empty');
    const countEl = document.getElementById('results-count');
    const statusEl = document.getElementById('results-status');
    const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-chip');

    let activeTag = '';
    let query = '';
    let pagefind: PagefindModule | null = null;
    let pagefindReady = false;
    let searchToken = 0;

    function normalize(url: string): string {
      return url.replace(/\/$/, '');
    }

    function updateCount(visible: number, total: number, filtering: boolean) {
      if (!countEl) return;
      const noun = visible === 1 ? 'post' : 'posts';
      countEl.textContent = filtering
        ? `Showing ${visible} of ${total} ${noun}`
        : `${total} ${total === 1 ? 'post' : 'posts'}`;
    }

    function showAll() {
      if (!grid) return;
      const cards = grid.querySelectorAll<HTMLElement>('.post-card');
      cards.forEach((c) => (c.hidden = false));
      updateCount(cards.length, cards.length, false);
      if (empty) empty.hidden = true;
      if (statusEl) statusEl.hidden = true;
    }

    async function initPagefind() {
      try {
        // Pagefind is generated at build time and served from /pagefind/pagefind.js.
        // In dev mode, astro-pagefind serves it from the last built dist folder —
        // so you must run `npm run build` once before search works in `npm run dev`.
        // @ts-expect-error - Loaded at runtime, no types
        pagefind = (await import(/* @vite-ignore */ '/pagefind/pagefind.js')) as PagefindModule;
        await pagefind.init();
        pagefindReady = true;
      } catch (err) {
        console.warn(
          'Pagefind not available. Run `npm run build` once to generate the search index.',
          err,
        );
        if (statusEl) {
          statusEl.hidden = false;
          statusEl.textContent = 'Search index unavailable';
        }
      }
    }

    async function applyFilter() {
      if (!grid) return;
      const cards = grid.querySelectorAll<HTMLElement>('.post-card');
      const total = cards.length;
      const filtering = !!query || !!activeTag;

      if (!filtering) {
        showAll();
        return;
      }

      if (!pagefindReady || !pagefind) {
        // Pagefind hasn't loaded — leave everything visible rather than break the page.
        showAll();
        return;
      }

      // Cancel any in-flight searches that finish after this one.
      const myToken = ++searchToken;

      try {
        const filters = activeTag ? { tag: activeTag } : {};
        const result = await pagefind.search(query || null, { filters });
        const datas = await Promise.all(result.results.map((r) => r.data()));
        if (myToken !== searchToken) return; // stale; a newer search ran

        const matching = new Set(datas.map((d) => normalize(d.url)));
        let visible = 0;
        cards.forEach((card) => {
          const href = normalize(card.getAttribute('href') ?? '');
          const isMatch = matching.has(href);
          card.hidden = !isMatch;
          if (isMatch) visible += 1;
        });
        if (empty) empty.hidden = visible !== 0;
        updateCount(visible, total, true);
        if (statusEl) statusEl.hidden = true;
      } catch (err) {
        console.error('Pagefind search failed:', err);
        showAll();
      }
    }

    searchEl?.addEventListener('input', (e) => {
      query = (e.target as HTMLInputElement).value.trim();
      applyFilter();
    });

    tagButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        tagButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeTag = btn.dataset.tag ?? '';
        applyFilter();
      });
    });

    initPagefind();
  </script>
</BaseLayout>

<style>
  .library {
    padding: 48px 0 64px;
  }
  .filters {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: 30px;
  }
  .search-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mute);
  }
  #search {
    background: var(--soft-cloud);
    border: 2px solid transparent;
    border-radius: 24px;
    padding: 0 20px;
    font-size: 16px;
    font-family: inherit;
    height: 48px;
    color: var(--ink);
    width: 100%;
    max-width: 520px;
    outline: none;
    transition: border-color 120ms ease, background 120ms ease;
  }
  #search:focus {
    background: var(--canvas);
    border-color: var(--ink);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-chip {
    background: var(--canvas);
    color: var(--ink);
    border: 1px solid var(--hairline);
    height: 40px;
    padding: 0 16px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    text-transform: capitalize;
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  .tag-chip:hover {
    border-color: var(--ink);
  }
  .tag-chip.active {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }

  .results-line {
    padding: 14px 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--mute);
    margin-bottom: 18px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .status {
    color: var(--sale);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  .empty {
    font-size: 16px;
    color: var(--mute);
    text-align: center;
    padding: 48px 0;
  }
  @media (max-width: 760px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
