---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, excerpt, sourceAuthor, sourceYear, concept, tags } = post.data;

const utilityRightParts: string[] = [];
if (concept) utilityRightParts.push(concept);
if (sourceAuthor) {
  utilityRightParts.push(
    sourceYear ? `${sourceAuthor}, ${sourceYear}` : sourceAuthor,
  );
}

const sourceLabel = sourceAuthor
  ? sourceYear
    ? `${sourceAuthor}, ${sourceYear}`
    : sourceAuthor
  : '';
---
<BaseLayout title={title} description={excerpt}>
  {utilityRightParts.length > 0 && (
    <Fragment slot="utility-right">
      {utilityRightParts.map((part) => <span>{part}</span>)}
    </Fragment>
  )}

  <article data-pagefind-body>
    {/* Pagefind metadata — hidden from view, picked up at index time */}
    <div data-pagefind-meta={`title:${title}`} hidden />
    <div data-pagefind-meta={`excerpt:${excerpt}`} hidden />
    {sourceLabel && (
      <div data-pagefind-meta={`source:${sourceLabel}`} hidden />
    )}
    {tags.map((tag) => (
      <div data-pagefind-filter={`tag:${tag}`} hidden />
    ))}

    <Content />
  </article>
</BaseLayout>
